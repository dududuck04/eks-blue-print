            "yaml_body": "apiVersion: karpenter.sh/v1\nkind: NodePool\nmetadata:\n  name: default\nspec:\n  template:\n    spec:\n      nodeClassRef:\n        group: karpenter.k8s.aws\n        kind: EC2NodeClass\n        name: default\n\n      expireAfter: Never\n      terminationGracePeriod: 48h\n\n      requirements:\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n          - key: \"kubernetes.io/arch\"\n            operator: In\n            values: [\"amd64\"]\n        \n\n        \n          - key: \"karpenter.sh/capacity-type\"\n            operator: In\n            values: [\"on-demand\",\"spot\"]\n        \n\n  disruption:\n    consolidationPolicy: WhenEmpty\n    consolidateAfter: 30s\n\n    budgets: []\n\n  limits:\n    cpu: 1000\n    memory: 1000Gi\n\n  weight: 10\n",
