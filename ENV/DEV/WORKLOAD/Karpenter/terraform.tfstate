    {
      "module": "module.karpenter.module.karpenter",
      "mode": "data",
      "type": "aws_iam_policy_document",
      "name": "v1",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "index_key": 0,
          "schema_version": 0,
          "attributes": {
            "id": "442556279",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"AllowScopedEC2InstanceAccessActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ec2:RunInstances\",\n        \"ec2:CreateFleet\"\n      ],\n      \"Resource\": [\n        \"arn:aws:ec2:ap-northeast-2::snapshot/*\",\n        \"arn:aws:ec2:ap-northeast-2::image/*\",\n        \"arn:aws:ec2:ap-northeast-2:*:subnet/*\",\n        \"arn:aws:ec2:ap-northeast-2:*:security-group/*\",\n        \"arn:aws:ec2:ap-northeast-2:*:capacity-reservation/*\"\n      ]\n    },\n    {\n      \"Sid\": \"AllowScopedEC2LaunchTemplateAccessActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ec2:RunInstances\",\n        \"ec2:CreateFleet\"\n      ],\n      \"Resource\": \"arn:aws:ec2:ap-northeast-2:*:launch-template/*\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:ResourceTag/kubernetes.io/cluster/poc-kkm-cluster\": \"owned\"\n        },\n        \"StringLike\": {\n          \"aws:ResourceTag/karpenter.sh/nodepool\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowScopedEC2InstanceActionsWithTags\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ec2:RunInstances\",\n        \"ec2:CreateLaunchTemplate\",\n        \"ec2:CreateFleet\"\n      ],\n      \"Resource\": [\n        \"arn:aws:ec2:ap-northeast-2:*:volume/*\",\n        \"arn:aws:ec2:ap-northeast-2:*:spot-instances-request/*\",\n        \"arn:aws:ec2:ap-northeast-2:*:network-interface/*\",\n        \"arn:aws:ec2:ap-northeast-2:*:launch-template/*\",\n        \"arn:aws:ec2:ap-northeast-2:*:instance/*\",\n        \"arn:aws:ec2:ap-northeast-2:*:fleet/*\"\n      ],\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:RequestTag/eks:eks-cluster-name\": \"poc-kkm-cluster\",\n          \"aws:RequestTag/kubernetes.io/cluster/poc-kkm-cluster\": \"owned\"\n        },\n        \"StringLike\": {\n          \"aws:RequestTag/karpenter.sh/nodepool\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowScopedResourceCreationTagging\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"ec2:CreateTags\",\n      \"Resource\": [\n        \"arn:aws:ec2:ap-northeast-2:*:volume/*\",\n        \"arn:aws:ec2:ap-northeast-2:*:spot-instances-request/*\",\n        \"arn:aws:ec2:ap-northeast-2:*:network-interface/*\",\n        \"arn:aws:ec2:ap-northeast-2:*:launch-template/*\",\n        \"arn:aws:ec2:ap-northeast-2:*:instance/*\",\n        \"arn:aws:ec2:ap-northeast-2:*:fleet/*\"\n      ],\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:RequestTag/eks:eks-cluster-name\": \"poc-kkm-cluster\",\n          \"aws:RequestTag/kubernetes.io/cluster/poc-kkm-cluster\": \"owned\",\n          \"ec2:CreateAction\": [\n            \"RunInstances\",\n            \"CreateFleet\",\n            \"CreateLaunchTemplate\"\n          ]\n        },\n        \"StringLike\": {\n          \"aws:RequestTag/karpenter.sh/nodepool\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowScopedResourceTagging\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"ec2:CreateTags\",\n      \"Resource\": \"arn:aws:ec2:ap-northeast-2:*:instance/*\",\n      \"Condition\": {\n        \"ForAllValues:StringEquals\": {\n          \"aws:TagKeys\": [\n            \"eks:eks-cluster-name\",\n            \"karpenter.sh/nodeclaim\",\n            \"Name\"\n          ]\n        },\n        \"StringEquals\": {\n          \"aws:ResourceTag/kubernetes.io/cluster/poc-kkm-cluster\": \"owned\"\n        },\n        \"StringEqualsIfExists\": {\n          \"aws:RequestTag/eks:eks-cluster-name\": \"poc-kkm-cluster\"\n        },\n        \"StringLike\": {\n          \"aws:ResourceTag/karpenter.sh/nodepool\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowScopedDeletion\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ec2:TerminateInstances\",\n        \"ec2:DeleteLaunchTemplate\"\n      ],\n      \"Resource\": [\n        \"arn:aws:ec2:ap-northeast-2:*:launch-template/*\",\n        \"arn:aws:ec2:ap-northeast-2:*:instance/*\"\n      ],\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:ResourceTag/kubernetes.io/cluster/poc-kkm-cluster\": \"owned\"\n        },\n        \"StringLike\": {\n          \"aws:ResourceTag/karpenter.sh/nodepool\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowRegionalReadActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ec2:DescribeSubnets\",\n        \"ec2:DescribeSpotPriceHistory\",\n        \"ec2:DescribeSecurityGroups\",\n        \"ec2:DescribeLaunchTemplates\",\n        \"ec2:DescribeInstances\",\n        \"ec2:DescribeInstanceTypes\",\n        \"ec2:DescribeInstanceTypeOfferings\",\n        \"ec2:DescribeImages\",\n        \"ec2:DescribeAvailabilityZones\"\n      ],\n      \"Resource\": \"*\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:RequestedRegion\": \"ap-northeast-2\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowSSMReadActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"ssm:GetParameter\",\n      \"Resource\": \"arn:aws:ssm:ap-northeast-2::parameter/aws/service/*\"\n    },\n    {\n      \"Sid\": \"AllowPricingReadActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"pricing:GetProducts\",\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"AllowInterruptionQueueActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"sqs:ReceiveMessage\",\n        \"sqs:GetQueueUrl\",\n        \"sqs:DeleteMessage\"\n      ],\n      \"Resource\": \"arn:aws:sqs:ap-northeast-2:539666729110:Karpenter-poc-kkm-cluster\"\n    },\n    {\n      \"Sid\": \"AllowPassingInstanceRole\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"iam:PassRole\",\n      \"Resource\": \"arn:aws:iam::539666729110:role/poc-kkm-karpenter-node-rol\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"iam:PassedToService\": \"ec2.amazonaws.com\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowScopedInstanceProfileCreationActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"iam:CreateInstanceProfile\",\n      \"Resource\": \"arn:aws:iam::539666729110:instance-profile/*\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:RequestTag/eks:eks-cluster-name\": \"poc-kkm-cluster\",\n          \"aws:RequestTag/kubernetes.io/cluster/poc-kkm-cluster\": \"owned\",\n          \"aws:RequestTag/topology.kubernetes.io/region\": \"ap-northeast-2\"\n        },\n        \"StringLike\": {\n          \"aws:RequestTag/karpenter.k8s.aws/ec2nodeclass\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowScopedInstanceProfileTagActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"iam:TagInstanceProfile\",\n      \"Resource\": \"arn:aws:iam::539666729110:instance-profile/*\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:RequestTag/eks:eks-cluster-name\": \"poc-kkm-cluster\",\n          \"aws:RequestTag/kubernetes.io/cluster/poc-kkm-cluster\": \"owned\",\n          \"aws:RequestTag/topology.kubernetes.io/region\": \"ap-northeast-2\",\n          \"aws:ResourceTag/kubernetes.io/cluster/poc-kkm-cluster\": \"owned\",\n          \"aws:ResourceTag/topology.kubernetes.io/region\": \"ap-northeast-2\"\n        },\n        \"StringLike\": {\n          \"aws:RequestTag/karpenter.k8s.aws/ec2nodeclass\": \"*\",\n          \"aws:ResourceTag/karpenter.k8s.aws/ec2nodeclass\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowScopedInstanceProfileActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"iam:RemoveRoleFromInstanceProfile\",\n        \"iam:DeleteInstanceProfile\",\n        \"iam:AddRoleToInstanceProfile\"\n      ],\n      \"Resource\": \"arn:aws:iam::539666729110:instance-profile/*\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:ResourceTag/kubernetes.io/cluster/poc-kkm-cluster\": \"owned\",\n          \"aws:ResourceTag/topology.kubernetes.io/region\": \"ap-northeast-2\"\n        },\n        \"StringLike\": {\n          \"aws:ResourceTag/karpenter.k8s.aws/ec2nodeclass\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowInstanceProfileReadActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"iam:GetInstanceProfile\",\n      \"Resource\": \"arn:aws:iam::539666729110:instance-profile/*\"\n    },\n    {\n      \"Sid\": \"AllowAPIServerEndpointDiscovery\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"eks:DescribeCluster\",\n      \"Resource\": \"arn:aws:eks:ap-northeast-2:539666729110:cluster/poc-kkm-cluster\"\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Sid\":\"AllowScopedEC2InstanceAccessActions\",\"Effect\":\"Allow\",\"Action\":[\"ec2:RunInstances\",\"ec2:CreateFleet\"],\"Resource\":[\"arn:aws:ec2:ap-northeast-2::snapshot/*\",\"arn:aws:ec2:ap-northeast-2::image/*\",\"arn:aws:ec2:ap-northeast-2:*:subnet/*\",\"arn:aws:ec2:ap-northeast-2:*:security-group/*\",\"arn:aws:ec2:ap-northeast-2:*:capacity-reservation/*\"]},{\"Sid\":\"AllowScopedEC2LaunchTemplateAccessActions\",\"Effect\":\"Allow\",\"Action\":[\"ec2:RunInstances\",\"ec2:CreateFleet\"],\"Resource\":\"arn:aws:ec2:ap-northeast-2:*:launch-template/*\",\"Condition\":{\"StringEquals\":{\"aws:ResourceTag/kubernetes.io/cluster/poc-kkm-cluster\":\"owned\"},\"StringLike\":{\"aws:ResourceTag/karpenter.sh/nodepool\":\"*\"}}},{\"Sid\":\"AllowScopedEC2InstanceActionsWithTags\",\"Effect\":\"Allow\",\"Action\":[\"ec2:RunInstances\",\"ec2:CreateLaunchTemplate\",\"ec2:CreateFleet\"],\"Resource\":[\"arn:aws:ec2:ap-northeast-2:*:volume/*\",\"arn:aws:ec2:ap-northeast-2:*:spot-instances-request/*\",\"arn:aws:ec2:ap-northeast-2:*:network-interface/*\",\"arn:aws:ec2:ap-northeast-2:*:launch-template/*\",\"arn:aws:ec2:ap-northeast-2:*:instance/*\",\"arn:aws:ec2:ap-northeast-2:*:fleet/*\"],\"Condition\":{\"StringEquals\":{\"aws:RequestTag/eks:eks-cluster-name\":\"poc-kkm-cluster\",\"aws:RequestTag/kubernetes.io/cluster/poc-kkm-cluster\":\"owned\"},\"StringLike\":{\"aws:RequestTag/karpenter.sh/nodepool\":\"*\"}}},{\"Sid\":\"AllowScopedResourceCreationTagging\",\"Effect\":\"Allow\",\"Action\":\"ec2:CreateTags\",\"Resource\":[\"arn:aws:ec2:ap-northeast-2:*:volume/*\",\"arn:aws:ec2:ap-northeast-2:*:spot-instances-request/*\",\"arn:aws:ec2:ap-northeast-2:*:network-interface/*\",\"arn:aws:ec2:ap-northeast-2:*:launch-template/*\",\"arn:aws:ec2:ap-northeast-2:*:instance/*\",\"arn:aws:ec2:ap-northeast-2:*:fleet/*\"],\"Condition\":{\"StringEquals\":{\"aws:RequestTag/eks:eks-cluster-name\":\"poc-kkm-cluster\",\"aws:Reque